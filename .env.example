# ============================================================
# LLM RAG Document QA 环境变量模板
# ============================================================
# 使用方法：
#   1. 复制本文件为 .env
#        cp .env.example .env
#   2. 在 .env 里填写真实 API Key
#   3. 修改 .env 后重启服务
#
# 注意：
#   - 真实 .env 不要提交到 Git
#   - 本文件只放示例值和说明，不放真实密钥


# ============================================================
# 应用运行配置
# ============================================================

# Docker Compose 暴露到本机的端口。
# 示例：
#   APP_PORT=8000  -> http://127.0.0.1:8000
#   APP_PORT=8001  -> http://127.0.0.1:8001
# 如果你直接用 uvicorn 启动，实际端口以 uvicorn --port 参数为准。
APP_PORT=8000

# 本地运行数据目录。
# 系统会把 SQLite 数据库、上传文件、PDF 渲染图片都放在这里。
# 本机默认是 ./data。
# Docker Compose 会把这个值覆盖成 /app/data，并把本机 ./data 挂载进去。
LLM_RAG_DATA_DIR=./data


# ============================================================
# 大模型配置
# ============================================================

# 主 LLM API Key。
# 用途包括：聊天回答、PDF 查询理解、文档画像、内容分布摘要、文档相关性过滤。
# 如果使用默认 DashScope 兼容地址，这里填写 DashScope / 百炼 API Key。
LLM_API_KEY=your_dashscope_or_openai_compatible_api_key

# OpenAI-compatible Chat Completions base URL。
# 默认是阿里云百炼 / DashScope 兼容模式地址。
# 如果换成其他兼容 OpenAI Chat Completions 的服务，需要同步修改这里。
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 后端使用的聊天模型名称。
# 当前代码默认使用 qwen3.5-35b-a3b。
# 如果你的服务商不支持这个模型名，改成服务商提供的准确模型标识。
LLM_MODEL=qwen3.5-35b-a3b

# 旧配置兼容字段。
# 代码会优先读取 LLM_API_KEY；如果 LLM_API_KEY 为空，再读取 DASHSCOPE_API_KEY。
# 推荐只填写 LLM_API_KEY，这里保持空。
DASHSCOPE_API_KEY=


# ============================================================
# 向量模型配置：SiliconFlow
# ============================================================

# SiliconFlow API Key。
# 需要它的场景：
#   - 上传或重建 PDF 索引
#   - 上传或重建 Excel 向量索引
#   - 使用向量检索提升语义召回
# 如果不配置，部分流程会退回 SQLite FTS，但检索质量会下降。
SILICONFLOW_API_KEY=your_siliconflow_api_key

# SiliconFlow embedding 接口地址。
SILICONFLOW_EMBEDDING_URL=https://api.siliconflow.cn/v1/embeddings

# Embedding 模型。
# 当前代码默认使用 BAAI/bge-m3。
# 已经建过索引后不要随意更换模型，否则新旧向量语义和维度可能不一致。
SILICONFLOW_EMBEDDING_MODEL=BAAI/bge-m3

# 每次 embedding 请求发送的文本数量。
# 如果遇到限流、超时或网络不稳定，可以调小，比如 8 或 4。
SILICONFLOW_EMBEDDING_BATCH_SIZE=16


# ============================================================
# OCR 配置：PaddleOCR 异步接口
# ============================================================

# PaddleOCR async API token。
# 上传新 PDF 或重建 PDF 索引时必须配置。
PADDLEOCR_TOKEN=your_paddleocr_token

# 传给 PaddleOCR 的 OCR 模型名。
PADDLEOCR_MODEL=PP-OCRv5

# PaddleOCR 异步任务接口。
# 代码会 POST 到这个地址创建 OCR 任务，并 GET {PADDLEOCR_JOB_URL}/{job_id}
# 轮询任务进度。
PADDLEOCR_JOB_URL=https://paddleocr.aistudio-app.com/api/v2/ocr/jobs

# 后台索引任务并发数。
# 本机开发建议保持 1，避免 API 限流、内存压力或多个大文件同时处理。
OCR_PIPELINE_MAX_WORKERS=1

# OCR 遇到可重试错误时的最大重试次数。
PADDLEOCR_RETRY_ATTEMPTS=3

# OCR 重试基础等待秒数。
# 实际等待时间会随重试次数递增，例如第 N 次约等待 5 * N 秒。
PADDLEOCR_RETRY_BACKOFF=5

# 如果 OCR 任务进度长时间没有变化，超过这个秒数就认为任务卡住。
PADDLEOCR_STALL_TIMEOUT=180

# 单个 OCR 任务最大等待秒数。
# 超过后会失败，用户可以在页面点击“重建索引”重试。
PADDLEOCR_JOB_TIMEOUT=1800

# PDF 页数超过该阈值时，会自动切成多个小 PDF 分段提交 OCR。
# 这样可以降低大文件 OCR 超时风险。
PADDLEOCR_CHUNK_PAGE_THRESHOLD=48

# 分段 OCR 时，每段包含的页数。
PADDLEOCR_CHUNK_SIZE=40


# ============================================================
# PDF 内容分布摘要配置
# ============================================================

# 生成 PDF “内容分布摘要”时，每次 LLM 调用允许输出的最大 token。
# 内容分布摘要类似：“第 1-4 页讲适用范围，第 5-22 页讲流程要求”。
DOCUMENT_CHAPTER_SUMMARY_MAX_TOKENS=4096

# 生成内容分布摘要时，每次发给 LLM 的页码范围大小。
# 例如 40 表示第 1-40 页一次、第 41-80 页一次。
# 数值越大，LLM 调用次数越少，但单次 prompt 越长。
DOCUMENT_CHAPTER_SUMMARY_CHUNK_SIZE=40


# ============================================================
# Excel 政策库检索配置
# ============================================================

# 可选的小模型分类器。
# 配置后，系统会调用这个模型把用户问题解析成关键词和过滤条件。
# 可以填 qwen-turbo、qwen-plus 等速度快、成本低的模型名。
# 留空时使用代码里的规则解析逻辑。
EXCEL_QUERY_CLASSIFIER_MODEL=

# 是否为 Excel 政策块建立和使用向量索引。
#   1 = 开启，使用 FTS + 向量混合检索
#   0 = 关闭，只使用 SQLite FTS
# 如果 sqlite-vec 不可用，或想节省 embedding 成本，可以设置为 0。
EXCEL_VECTOR_INDEX_ENABLED=1
