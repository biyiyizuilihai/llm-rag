PADDLEOCR_TOKEN=your_paddleocr_token
PADDLEOCR_MODEL=PP-OCRv5
PADDLEOCR_JOB_URL=https://paddleocr.aistudio-app.com/api/v2/ocr/jobs

DASHSCOPE_API_KEY=your_dashscope_api_key

SILICONFLOW_API_KEY=your_siliconflow_api_key
SILICONFLOW_EMBEDDING_URL=https://api.siliconflow.cn/v1/embeddings
SILICONFLOW_EMBEDDING_MODEL=BAAI/bge-m3
SILICONFLOW_EMBEDDING_BATCH_SIZE=16

OCR_PIPELINE_MAX_WORKERS=1
PADDLEOCR_RETRY_ATTEMPTS=3
PADDLEOCR_RETRY_BACKOFF=5
PADDLEOCR_STALL_TIMEOUT=180
PADDLEOCR_JOB_TIMEOUT=1800
PADDLEOCR_CHUNK_PAGE_THRESHOLD=48
PADDLEOCR_CHUNK_SIZE=40

# Excel query classifier (optional).
# When set, uses this model to parse the user question into a structured query plan
# (intent, keywords, filters) with dynamic enum injection from the indexed document.
# Recommended: a fast/cheap model such as qwen-turbo or qwen-plus.
# Leave empty to use the built-in rule-based fallback.
EXCEL_QUERY_CLASSIFIER_MODEL=

# Excel vector index (set to 0 to disable, e.g. if sqlite-vec is unavailable)
EXCEL_VECTOR_INDEX_ENABLED=1

# Elasticsearch / OpenSearch (optional, for A/B diagnostics only — not the production answer path)
ELASTICSEARCH_URL=
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_INDEX_PREFIX=llm_rag
ELASTICSEARCH_CHINESE_ANALYZER=ik_max_word
ELASTICSEARCH_CHINESE_SEARCH_ANALYZER=ik_smart
